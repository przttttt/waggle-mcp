{
  "mcpServers": {
    "waggle": {
      "command": "node",
      "args": [
        "./bin/waggle-server-launcher.js",
        "serve",
        "--transport",
        "stdio"
      ],
      "env": {
        "WAGGLE_BACKEND": "sqlite",
        "WAGGLE_DB_PATH": "~/.waggle/waggle.db",
        "WAGGLE_DEFAULT_TENANT_ID": "local-default",
        "WAGGLE_MODEL": "all-MiniLM-L6-v2",
        "WAGGLE_TRANSPORT": "stdio"
      }
    }
  }
}
